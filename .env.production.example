# Copy this file to .env on the server and replace all CHANGE_ME values.
# Do not commit the real .env file.

NODE_ENV=production
PORT=4000
FRONTEND_HOST_PORT=3001

MYSQL_DATABASE=projectbt
MYSQL_USER=projectbt_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

DATABASE_URL="mysql://projectbt_user:CHANGE_ME_STRONG_DB_PASSWORD@db:3306/projectbt?allowPublicKeyRetrieval=true&ssl=false"

JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES=15m

COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Replace with the real production domain, for example:
# CORS_ORIGIN=https://projectbt.example.com
CORS_ORIGIN=https://CHANGE_ME_DOMAIN
